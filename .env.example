# Required — get these from https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Point these at a persistent, writable location in production (a mounted
# volume on Railway/Render/Fly.io, or a real path on a VPS/Docker host).
# Leave both unset and the app will pick a sensible default automatically:
# ./data and ./downloads on a normal persistent host, or a temp directory
# if it detects the app directory itself isn't writable (e.g. Vercel).
DATA_DIR=
DOWNLOAD_ROOT=

# Optional. After your first successful login, copy the string from
# <DATA_DIR>/session.txt into this variable on your host so the session
# survives even if the host's disk doesn't persist across deploys.
TELEGRAM_SESSION=

# Optional. Minutes to keep a completed download before it's auto-deleted.
# Defaults to 60. Set to 0 to disable time-based cleanup (downloads are still
# deleted on logout and on tab close/refresh — see README).
FILE_RETENTION_MINUTES=60
